# Instagram API Configuration
# Copy this file to .env and fill in your credentials

# Instagram Graph API (for future automation)
INSTAGRAM_ACCESS_TOKEN=your_long_lived_access_token_here
INSTAGRAM_USER_ID=your_instagram_business_user_id

# Facebook App (required for Instagram API)
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# Posting Configuration
POSTING_TIME=08:00
TIMEZONE=Asia/Tokyo

# Content Paths
PDF_PATH=/home/pankaj/autolinkedin/final_pdfs_collection
TRACKER_PATH=/home/pankaj/autolinkedin/instagram_app/tracker
TRACKER_FILE=posting_tracker.txt

# Logging
LOG_LEVEL=INFO
LOG_FILE=/home/pankaj/autolinkedin/instagram_app/logs/posting_history.log

# Features
ENABLE_AUTOMATION=false
ENABLE_ANALYTICS=false
SKIP_WEEKENDS=false

# Retry Configuration
MAX_RETRY_ATTEMPTS=3
RETRY_DELAY_SECONDS=300

# Notifications (optional)
ENABLE_EMAIL_NOTIFICATIONS=false
NOTIFICATION_EMAIL=your_email@example.com
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
